<?xml version="1.0"?>
<ruleset name="Museum Railway Timetable">
    <description>PHP CodeSniffer rules for Museum Railway Timetable plugin</description>

    <file>./inc</file>
    <file>./museum-railway-timetable.php</file>

    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>

    <arg name="extensions" value="php"/>
    <arg value="sp"/>
    <arg name="colors"/>
    <arg name="parallel" value="8"/>
    <arg name="warning-severity" value="0"/>

    <!-- WordPress Coding Standards -->
    <rule ref="WordPress">
        <exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
        <exclude name="WordPress.Files.FileName.NotHyphenatedLowercase"/>
        <exclude name="Generic.Files.LineLength.TooLong"/>
        <!-- MRT_* names are public plugin hooks/callbacks and must remain stable. -->
        <exclude name="WordPress.NamingConventions.ValidFunctionName.FunctionNameInvalid"/>
        <!-- Established dateYmd-style variables are used across public helper signatures. -->
        <exclude name="WordPress.NamingConventions.ValidVariableName.VariableNotSnakeCase"/>
        <!-- The plugin centralizes its text domain in MRT_TEXT_DOMAIN. -->
        <exclude name="WordPress.WP.I18n.NonSingularStringLiteralDomain"/>
        <!-- Translators comments will be added selectively where wording is ambiguous. -->
        <exclude name="WordPress.WP.I18n.MissingTranslatorsComment"/>
        <!-- The codebase uses natural-order comparisons consistently. -->
        <exclude name="WordPress.PHP.YodaConditions.NotYoda"/>
        <!-- Existing admin screens use nonce helper functions PHPCS cannot infer. -->
        <exclude name="WordPress.Security.NonceVerification"/>
        <exclude name="WordPress.Security.ValidatedSanitizedInput"/>
        <!-- Template helpers return already-escaped markup in several render pipelines. -->
        <exclude name="WordPress.Security.EscapeOutput"/>
        <!-- WordPress DB sniffs do not handle dynamic table names well for this custom table. -->
        <exclude name="WordPress.DB.PreparedSQL"/>
        <exclude name="WordPress.DB.DirectDatabaseQuery"/>
        <exclude name="WordPress.DB.SlowDBQuery"/>
        <!-- The timetable domain intentionally uses site-local dates/times in several views. -->
        <exclude name="WordPress.DateTime"/>
        <!-- Deprecated helpers are isolated legacy lookup paths; replacing them is separate behavior work. -->
        <exclude name="WordPress.WP.DeprecatedFunctions"/>
        <!-- Short ternaries are used for simple display fallbacks in legacy templates. -->
        <exclude name="Universal.Operators.DisallowShortTernary.Found"/>
    </rule>

    <!-- Existing code has many terse helper/doc comments; keep PHPCS focused on executable standards. -->
    <rule ref="Squiz.Commenting.FunctionComment">
        <severity>0</severity>
    </rule>
    <rule ref="Squiz.Commenting.FileComment">
        <severity>0</severity>
    </rule>
    <rule ref="Squiz.Commenting.InlineComment.InvalidEndChar">
        <severity>0</severity>
    </rule>
    <rule ref="PSR12.Files.FileHeader.IncorrectOrder">
        <severity>0</severity>
    </rule>
    <rule ref="Generic.Commenting.DocComment.MissingShort">
        <severity>0</severity>
    </rule>
    <rule ref="Squiz.PHP.DisallowMultipleAssignments.Found">
        <severity>0</severity>
    </rule>

    <!-- PHP version -->
    <config name="testVersion" value="8.0-"/>
</ruleset>
