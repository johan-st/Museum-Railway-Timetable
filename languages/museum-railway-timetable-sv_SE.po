msgid "These tools are only available when WP_DEBUG is enabled."
msgstr "Dessa verktyg är endast tillgängliga när WP_DEBUG är aktiverat."

msgid "Clear All Timetable Data"
msgstr "Rensa all tidtabellsdata"

msgid "Are you sure you want to delete ALL timetable data? This cannot be undone!"
msgstr "Är du säker på att du vill radera ALL tidtabellsdata? Detta kan inte ångras!"

msgid "This will delete all Stations, Services, Routes, Stop Times, and Calendar entries. Use with caution!"
msgstr "Detta kommer att radera alla Stations, Services, Routes, Stop Times och Calendar-poster. Använd med försiktighet!"

msgid "All timetable data has been cleared."
msgstr "All tidtabellsdata har rensats."

msgid "Security check failed."
msgstr "Säkerhetskontroll misslyckades."

# New translations for dashboard and UI improvements
msgid "Trips (Services)"
msgstr "Turer (Services)"

msgid "Managed via Timetables"
msgstr "Hanteras via Tidtabeller"

msgid "Routes Overview"
msgstr "Översikt över sträckor"

msgid "Routes define which stations trains travel between and in what order. When creating a trip, you select a route to automatically get all its stations."
msgstr "Sträckor definierar vilka stationer tåg reser mellan och i vilken ordning. När du skapar en tur väljer du en sträcka för att automatiskt få alla dess stationer."

