msgid "Click on any row to edit. Click \"Add New\" to add a new stop time."
msgstr "Klicka på en rad för att redigera. Klicka på \"Lägg till\" för att lägga till en ny hållplats."

msgid "Click on any row to edit. Click \"Add New\" to add a new calendar entry."
msgstr "Klicka på en rad för att redigera. Klicka på \"Lägg till\" för att lägga till en ny kalenderpost."

msgid "Route Details"
msgstr "Sträckdetaljer"

msgid "Define which stations are on this route, in order. The route works in both directions."
msgstr "Definiera vilka stationer som finns på sträckan, i ordning. Sträckan fungerar i båda riktningar."

msgid "Order"
msgstr "Ordning"

msgid "Remove"
msgstr "Ta bort"

msgid "Example route name: \"Hultsfred - Västervik\" or \"Main Line\". Add stations in the order they appear on the route."
msgstr "Exempel på sträcknamn: \"Hultsfred - Västervik\" eller \"Huvudlinje\". Lägg till stationer i den ordning de förekommer på sträckan."

msgid "— Select Route —"
msgstr "— Välj sträcka —"

msgid "Select the route this service runs on. Stations will be available from the selected route."
msgstr "Välj sträckan som denna service kör på. Stationer kommer att begränsas till de på sträckan."

msgid "Route selected: Stations are limited to those on the route."
msgstr "Sträcka vald: Stationer är begränsade till de på sträckan."

msgid "No route selected. Select a route in Service Details to limit stations to the route."
msgstr "Ingen sträcka vald. Välj en sträcka i Service Details för att begränsa stationer till sträckan."

